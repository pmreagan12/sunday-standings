    <script>
        let demoFilter = 'ALL';
        const demoGolfers = [
            { name: 'Scottie Scheffler', type: 'PRO', course: 'USA / PGA Tour', metric: '16.38 pts', rank: 1 },
            { name: 'Rory McIlroy', type: 'PRO', course: 'NIR / DP World', metric: '9.26 pts', rank: 2 },
            { name: 'Cameron Young', type: 'PRO', course: 'USA / PGA Tour', metric: '8.33 pts', rank: 3 },
            { name: 'Patrick (You)', type: 'PEER', course: 'Bloomington CC, MN', metric: '78.4 avg', rank: 12, isUser: true },
            { name: 'Jack', type: 'PEER', course: 'Hyland Hills, MN', metric: '82.1 avg', rank: 28 },
            { name: 'Ned', type: 'PEER', course: 'Dwan Park, MN', metric: '86.5 avg', rank: 45 }
        ];

        function renderDemoTable() {
            const tbody = document.getElementById('demoLeaderboardBody');
            tbody.innerHTML = '';

            const list = demoGolfers.filter(g => {
                if (demoFilter === 'PEERS') return g.type === 'PEER';
                if (demoFilter === 'PROS') return g.type === 'PRO';
                return true;
            });

            list.forEach(g => {
                const tr = document.createElement('tr');
                tr.className = g.isUser 
                    ? 'bg-emerald-950/40 border-l-4 border-l-golfgreen font-medium' 
                    : 'hover:bg-slate-800/40 transition-colors';

                const typeBadge = g.type === 'PRO'
                    ? `<span class="bg-blue-500/10 text-blue-400 border border-blue-500/20 px-2 py-0.5 rounded text-[10px] font-bold">OWGR PRO</span>`
                    : `<span class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded text-[10px] font-bold">AMATEUR</span>`;

                tr.innerHTML = `
                    <td class="py-3.5 px-4 sm:px-6 font-mono font-bold ${g.rank <= 3 ? 'text-amber-400' : 'text-slate-300'}">#${g.rank}</td>
                    <td class="py-3.5 px-4 sm:px-6 font-bold text-white flex items-center gap-2">
                        <span>${g.name}</span>
                        ${g.isUser ? '<span class="text-[10px] bg-emerald-500 text-slate-950 px-1.5 py-0.2 rounded font-bold">YOU</span>' : ''}
                    </td>
                    <td class="py-3.5 px-4 sm:px-6">${typeBadge}</td>
                    <td class="py-3.5 px-4 sm:px-6 text-slate-400">${g.course}</td>
                    <td class="py-3.5 px-4 sm:px-6 text-right font-mono font-bold text-emerald-400">${g.metric}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function setDemoFilter(filter) {
            demoFilter = filter;
            document.querySelectorAll('#demo button[id^="demoTab"]').forEach(btn => {
                btn.className = 'px-3 py-1.5 rounded-md text-xs font-semibold text-slate-400 hover:text-white transition';
            });
            document.getElementById(`demoTab${filter}`).className = 'px-3 py-1.5 rounded-md text-xs font-semibold bg-[#009069] text-slate-950 transition';
            renderDemoTable();
        }

        function openModal(id) {
            document.getElementById(id).classList.remove('hidden');
        }

        function closeModal(id) {
            document.getElementById(id).classList.add('hidden');
        }

        function handleWaitlistSubmit(e) {
            e.preventDefault();
            const name = document.getElementById('waitlistName').value;
            closeModal('waitlistModal');
            alert(`Welcome aboard, ${name}! Your early access handle has been reserved.`);
        }

        window.onload = function() {
            renderDemoTable();
        };
    </script>
